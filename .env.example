LOGION_ENV=development
LOGION_VERSION=0.1.0
LOGION_LOG_LEVEL=INFO
LOGION_API_HOST=0.0.0.0
LOGION_API_PORT=8000
LOGION_DATABASE_URL=postgresql+asyncpg://logion:change-me@postgres:5432/logion
LOGION_REDIS_URL=redis://redis:6379/0
LOGION_PUBLIC_API_URL=http://localhost:8000
LOGION_ALLOWED_ORIGINS=["http://localhost:3000"]
LOGION_HEALTHCHECK_DEPENDENCIES=false
LOGION_SECRET_KEY=replace-with-at-least-32-random-characters
LOGION_COOKIE_SECURE=false
LOGION_LOGIN_IP_LIMIT_PER_FIVE_MINUTES=30
LOGION_LOGIN_ACCOUNT_LIMIT_PER_FIVE_MINUTES=10
POSTGRES_DB=logion
POSTGRES_USER=logion
POSTGRES_PASSWORD=change-me
LOGION_BACKUP_RETENTION_DAYS=14
NEXT_TELEMETRY_DISABLED=1
