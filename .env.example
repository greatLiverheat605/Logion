LOGION_ENV=development
LOGION_VERSION=0.1.0
LOGION_LOG_LEVEL=INFO
LOGION_API_HOST=0.0.0.0
LOGION_API_PORT=8000
LOGION_DATABASE_URL=postgresql+asyncpg://logion:change-me@postgres:5432/logion
LOGION_REDIS_URL=redis://redis:6379/0
LOGION_PUBLIC_API_URL=http://localhost:8000
LOGION_ALLOWED_ORIGINS=["http://localhost:3000"]
LOGION_HEALTHCHECK_DEPENDENCIES=false
LOGION_SECRET_KEY=replace-with-at-least-32-random-characters
LOGION_COOKIE_SECURE=false
LOGION_LEGACY_REGISTRATION_ENABLED=true
LOGION_EMAIL_REGISTRATION_IP_LIMIT_PER_HOUR=10
LOGION_EMAIL_REGISTRATION_ACCOUNT_LIMIT_PER_HOUR=3
LOGION_EMAIL_VERIFICATION_CONFIRM_LIMIT_PER_FIVE_MINUTES=30
LOGION_EMAIL_VERIFICATION_TTL_HOURS=24
LOGION_PASSWORD_RECOVERY_IP_LIMIT_PER_HOUR=10
LOGION_PASSWORD_RECOVERY_ACCOUNT_LIMIT_PER_HOUR=3
LOGION_PASSWORD_RECOVERY_COMPLETE_LIMIT_PER_FIVE_MINUTES=20
LOGION_PASSWORD_RECOVERY_TTL_MINUTES=30
LOGION_PASSWORD_RECOVERY_MAX_FAILURES=5
LOGION_LOGIN_IP_LIMIT_PER_FIVE_MINUTES=30
LOGION_LOGIN_ACCOUNT_LIMIT_PER_FIVE_MINUTES=10
LOGION_WORKSPACE_CREATE_LIMIT_PER_HOUR=10
LOGION_SPACE_CREATE_LIMIT_PER_HOUR=60
LOGION_WORKSPACE_OWNED_QUOTA=10
LOGION_SPACE_PER_WORKSPACE_QUOTA=200
LOGION_WEBAUTHN_RP_ID=localhost
LOGION_WEBAUTHN_RP_NAME=Logion
LOGION_WEBAUTHN_ORIGINS=["http://localhost:3000"]
LOGION_TOTP_ACTIVE_ENCRYPTION_KEY_ID=development-v1
LOGION_TOTP_ENCRYPTION_KEYS={"development-v1":"ZGV2ZWxvcG1lbnQtb25seS10b3RwLWtleS0zMmJ5dGU"}
LOGION_EMAIL_DELIVERY_ACTIVE_ENCRYPTION_KEY_ID=development-v1
LOGION_EMAIL_DELIVERY_ENCRYPTION_KEYS={"development-v1":"ZGV2ZWxvcG1lbnQtZW1haWwta2V5LTMyYnl0ZXMhISE"}
LOGION_AI_CREDENTIAL_ACTIVE_ENCRYPTION_KEY_ID=development-v1
LOGION_AI_CREDENTIAL_ENCRYPTION_KEYS={"development-v1":"ZGV2ZWxvcG1lbnQtYWkta2V5LTMyYnl0ZXMhISEhISE"}
LOGION_DATA_EXPORT_ACTIVE_ENCRYPTION_KEY_ID=development-v1
LOGION_DATA_EXPORT_ENCRYPTION_KEYS={"development-v1":"ZGV2ZWxvcG1lbnQtZXhwb3J0LWtleS0zMmJ5dGVzISE"}
LOGION_ATTACHMENT_ROOT=/attachments
LOGION_ATTACHMENT_MAX_BYTES=20971520
LOGION_ATTACHMENT_USER_QUOTA_BYTES=524288000
LOGION_FORWARDED_ALLOW_IPS=*
POSTGRES_DB=logion
POSTGRES_USER=logion
POSTGRES_PASSWORD=change-me
LOGION_BACKUP_RETENTION_DAYS=14
# Create this ignored file with a base64url-encoded 32-byte random key.
LOGION_BACKUP_SECRET_SOURCE=./secrets/backup.key
LOGION_BACKUP_KEY_ID=development-v1
NEXT_TELEMETRY_DISABLED=1
