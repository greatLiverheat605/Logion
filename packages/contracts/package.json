{
  "name": "@logion/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./permissions": "./permissions/permissions.json",
    "./schemas/*": "./schemas/*"
  },
  "scripts": {
    "generate:sync": "node scripts/generate-sync-types.mjs",
    "generate:types": "openapi-typescript openapi/openapi.json -o src/openapi.d.ts",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@logion/config": "workspace:*",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "json-canonicalize": "2.0.0",
    "json-schema-to-typescript": "15.0.4",
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.6",
    "typescript": "5.9.3"
  }
}
